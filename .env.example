# ---------------------------------------------------------------------------
# Variáveis de ambiente do serviço de webhook do Instagram.
# Copie este arquivo para ".env" e preencha com os seus valores.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Token que VOCÊ inventa. Você vai digitar exatamente este mesmo valor no painel
# da Meta na hora de verificar o webhook. Pode ser qualquer string secreta.
WEBHOOK_VERIFY_TOKEN=troque_por_um_token_secreto

# Token de acesso de longa duração do fluxo "Instagram API with Instagram Login"
# (começa com "IGAA", validade de ~60 dias). Gerado no painel da Meta (veja o README).
IG_ACCESS_TOKEN=seu_long_lived_access_token

# App Secret do seu app da Meta (Configurações do app > Básico).
# Usado para validar a assinatura dos webhooks (X-Hub-Signature-256).
# Em testes locais você pode deixar vazio para PULAR a validação — não faça isso em produção.
APP_SECRET=seu_app_secret

# ID da sua conta profissional do Instagram (IG User ID / IG Business Account ID).
IG_USER_ID=seu_ig_user_id

# Versão da Graph API. Padrão: v21.0
GRAPH_VERSION=v21.0

# --- Supabase ---------------------------------------------------------------
# Project URL (Dashboard > Project Settings > API). SEM barra no final.
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Chave service_role (NÃO a anon). Server-side only — nunca exponha no frontend.
SUPABASE_KEY=sua_service_role_key

# --- Anthropic (Claude) -----------------------------------------------------
# API key da Anthropic (console.anthropic.com). Conta separada do Claude.ai.
ANTHROPIC_API_KEY=sk-ant-sua_chave
# Modelo (padrão recomendado).
ANTHROPIC_MODEL=claude-opus-4-8
